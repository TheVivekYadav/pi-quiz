      "text": "Which of the following best describes Newton's First Law of Motion?",
      "options": [
        { "id": "opt_q1_a", "label": "An object at rest stays at rest unless acted upon by an external force" },
        { "id": "opt_q1_b", "label": "Force equals mass times acceleration" },
        { "id": "opt_q1_c", "label": "For every action there is an equal and opposite reaction" },
        { "id": "opt_q1_d", "label": "The rate of change of momentum equals applied force" }
      ],
      "correctOptionId": "opt_q1_a",
      "points": 2
    },
    {
      "placeholder": "q2",
      "text": "What is the formula for kinetic energy?",
      "options": [
        { "id": "opt_q2_a", "label": "KE = mgh" },
        { "id": "opt_q2_b", "label": "KE = ½mv²" },
        { "id": "opt_q2_c", "label": "KE = mv" },
        { "id": "opt_q2_d", "label": "KE = F·d" }
      ],
      "correctOptionId": "opt_q2_b",
      "points": 2
    },
    {
