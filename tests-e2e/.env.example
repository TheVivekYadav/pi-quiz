# Base URL for the web app under test.
# Defaults to https://pit.engineer if not set.
BASE_URL=http://localhost:80

# Roll number used for the authenticated user in E2E tests.
# This account must exist (or be auto-created on first login) in the target DB.
TEST_USER_ROLL=TEST001

# Roll number of the admin account used in admin-flow tests.
# Must have role=admin in the database.
TEST_ADMIN_ROLL=ADMIN001
