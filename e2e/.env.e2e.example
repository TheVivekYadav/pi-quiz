# Copy this file to .env.e2e and fill in values for local development.
# This file is committed; .env.e2e is gitignored.

# PostgreSQL connection for globalSetup (E2E-isolated DB)
E2E_DB_URL=postgresql://pi_quiz:pi_quiz_password@localhost:5433/pi_quiz_e2e

# Where the NestJS API is listening during tests
E2E_API_URL=http://localhost:3001

# Where the Expo web build is served during tests
E2E_APP_URL=http://localhost:4000

# Tell the Expo web app to talk to the E2E API
EXPO_PUBLIC_API_BASE_URL=http://localhost:3001/api

# Test accounts (must match seeds in globalSetup.ts)
E2E_ADMIN_ROLL=ADMIN001
E2E_USER_ROLL=TESTUSER001
